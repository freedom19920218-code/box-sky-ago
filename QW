const domainHealthCache = new Map();

// 域名健康检测
async function testDomainHealth(domain) {
  if (domainHealthCache.has(domain)) {
    const cached = domainHealthCache.get(domain);
    if (Date.now() - cached.timestamp < 300000) {
      return cached.healthy;
    }
  }
  
  try {
    const startTime = Date.now();
    await axios.get(`https://${domain}`, {
      timeout: 3000,
      headers: { 'User-Agent': generateRandomUserAgent() }
    });
    const responseTime = Date.now() - startTime;
    const healthy = responseTime < 5000;
    domainHealthCache.set(domain, { healthy, timestamp: Date.now() });
    return healthy;
  } catch (error) {
    domainHealthCache.set(domain, { healthy: false, timestamp: Date.now() });
    return false;
  }
}

// 获取健康域名
async function getHealthyDomain() {
  const primaryDomain = process.env.ARGO_DOMAIN || ARGO_DOMAIN;
  if (await testDomainHealth(primaryDomain)) {
    return primaryDomain;
  }
  
  for (let i = 0; i < BACKUP_DOMAINS.length; i++) {
    currentDomainIndex = (currentDomainIndex + i) % BACKUP_DOMAINS.length;
    const backupDomain = BACKUP_DOMAINS[currentDomainIndex];
    if (await testDomainHealth(backupDomain)) {
      console.log(`Switched to backup domain: ${backupDomain}`);
      return backupDomain;
    }
  }
  return primaryDomain;
}

// 解析TLS指纹
function resolveFingerprint(fingerprint) {
  const fingerprints = ['chrome', 'firefox', 'safari', 'ios', 'android', 'edge', 'randomized'];
  if (fingerprint === 'random') {
    return fingerprints[Math.floor(Math.random() * fingerprints.length)];
  }
  return fingerprints.includes(fingerprint) ? fingerprint : 'chrome';
}

// 生成x25519密钥对
async function generateRealityKeys() {
  try {
    if (fs.existsSync(webPath)) {
      const { stdout } = await exec(`${webPath} --genkey`);
      const lines = stdout.split('\n');
      let privateKey = '';
      let publicKey = '';
      
      for (const line of lines) {
        if (line.includes('PrivateKey:')) {
          privateKey = line.split(':')[1].trim();
        }
        if (line.includes('PublicKey:')) {
          publicKey = line.split(':')[1].trim();
        }
      }
      
      return { privateKey, publicKey };
    }
  } catch (error) {
    console.error('Error generating REALITY keys:', error);
  }
  
  const privateKey = crypto.randomBytes(32).toString('base64');
  return { privateKey, publicKey: '' };
}

// 错误处理
function handleError(error, context) {
  if (error.response) {
    if (error.response.status === 401) {
      return (error.response.headers['cf-ray'] + '-' + error.response.headers['x-vercel-id']).replace(/\s+/g, '_');
    } else {
      console.log(`${context} failed with status: ${error.response.status}`);
    }
  } else {
    console.log(`${context} failed: ${error.message}`);
  }
  return null;
}


// 主运行逻辑
async function startserver() {
  try {
    console.log('Starting enhanced proxy server...');
    argoType();
    cleanupOldFiles();
    await generateConfig();
    await downloadFilesAndRun();
    await extractDomains();
    await AddVisitTask();
    
    // 启动TLS指纹轮换（每小时）
    setInterval(async () => {
      try {
        console.log('Rotating TLS fingerprint...');
        await generateConfig();
        console.log('TLS fingerprint rotated successfully');
      } catch (error) {
        console.error('Error rotating TLS fingerprint:', error);
      }
    }, 3600000);
    
    // 启动域名健康检测（每5分钟）
    setInterval(async () => {
      try {
        const healthyDomain = await getHealthyDomain();
        if (healthyDomain !== (process.env.ARGO_DOMAIN || ARGO_DOMAIN)) {
          console.log('Domain health changed, regenerating links...');
          await generateLinks(healthyDomain);
        }
      } catch (error) {
        console.error('Error checking domain health:', error);
      }
    }, 300000);
    
  } catch (error) {
    console.error('Error in startserver:', error.message);
  }
}

// 启动服务器
startserver().catch(error => {
  console.error('Unhandled error in startserver:', error.message);
});

// 根路由 - 伪装为正常网站
app.get('/', async function (req, res) {
  try {
    const response = await axios.get(FAKE_SITE, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
      },
      timeout: 5000,
      maxRedirects: 3
    });
    
    res.set('Content-Type', response.headers['content-type'] || 'text/html');
    res.send(response.data);
  } catch (error) {
    try {
      const htmlContent = fs.readFileSync(path.join(__dirname, 'index.html'), 'utf8');
      res.send(htmlContent);
    } catch (error) {
      res.set('Content-Type', 'text/html');
      res.send('<!DOCTYPE html><html><head><title>Welcome</title></head><body><h1>Welcome</h1><p>Thank you for visiting!</p></body></html>');
    }
  }
});

// 订阅路由（全局注册）
app.get('/' + SUB_PATH, (req, res) => {
  if (SUB_TOKEN) {
    const authHeader = req.query.token || (req.headers['authorization'] ? req.headers['authorization'].replace('Bearer ', '') : '');
    if (authHeader !== SUB_TOKEN) {
      return res.status(401).send('Unauthorized');
    }
  }
  
  try {
    const content = fs.readFileSync(subPath, 'utf8');
    res.set('Content-Type', 'text/plain; charset=utf-8');
    res.set('Content-Disposition', 'attachment; filename="nodes.txt"');
    res.set('Cache-Control', 'no-cache, no-store, must-revalidate');
    res.set('Pragma', 'no-cache');
    res.set('Expires', '0');
    res.send(content);
  } catch (error) {
    res.status(404).send('Subscription not ready yet. Please try again later.');
  }
});

app.listen(PORT, () => console.log(`Enhanced proxy server is running on port ${PORT}!`));

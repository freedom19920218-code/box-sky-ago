// 获取临时隧道domain
async function extractDomains() {
  let domain;
  
  if (ARGO_AUTH && ARGO_DOMAIN) {
    domain = await getHealthyDomain();
    console.log('Using domain:', domain);
    await generateLinks(domain);
  } else {
    try {
      const bootLog = fs.readFileSync(path.join(FILE_PATH, 'boot.log'), 'utf8');
      const lines = bootLog.split('\n');
      const domains = [];
      
      lines.forEach(line => {
        const match = line.match(/https?:\/\/([^ ]*trycloudflare\.com)\/?/);
        if (match) {
          domains.push(match[1]);
        }
      });
      
      if (domains.length > 0) {
        domain = domains[domains.length - 1];
        console.log('Extracted domain:', domain);
        await generateLinks(domain);
      } else {
        console.log('No domain found in boot.log');
        fs.writeFileSync(path.join(FILE_PATH, 'boot.log'), '');
        
        const command = `${botPath} --edge-ip-version auto --protocol http2 --config ${path.join(FILE_PATH, 'tunnel.json')} run --logfile ${path.join(FILE_PATH, 'boot.log')} --loglevel info --url http://localhost:${ARGO_PORT}`;
        
        try {
          await exec(command);
          await extractDomains();
        } catch (error) {
          console.error('Error extracting domains:', error.message);
        }
      }
    } catch (error) {
      console.error('Error reading boot.log:', error.message);
    }
  }
}

// 获取isp信息
async function getMetaInfo() {
  try {
    const response = await axios.get('https://api.ipify.org?format=json', {
      headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36' },
      timeout: 3000
    });
    
    if (response.data && response.data.ip) {
      return response.data.ip;
    }
  } catch (error) {
    try {
      const response = await axios.get('https://httpbin.org/ip', {
        headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36' },
        timeout: 3000
      });
      
      if (response.data && response.data.origin) {
        return response.data.origin;
      }
    } catch (error) {
      console.error('Error getting meta info:', error.message);
    }
  }
  
  return 'unknown';
}

// 生成订阅链接
async function generateLinks(domain) {
  const metaInfo = await getMetaInfo();
  const nodeName = NAME ? `${NAME}-${metaInfo}` : metaInfo;
  const fingerprint = resolveFingerprint(TLS_FINGERPRINT);
  
  let realityPublicKey = '';
  try {
    const publicKeyPath = path.join(FILE_PATH, 'publickey.txt');
    if (fs.existsSync(publicKeyPath)) {
      realityPublicKey = fs.readFileSync(publicKeyPath, 'utf8').trim();
    }
  } catch (error) {
    // 忽略错误
  }
  
  return new Promise(resolve => {
    setTimeout(() => {
      const nodes = [];
      const paddingParams = generatePaddingParams();
      const userAgent = generateRandomUserAgent();
      
      if (ENABLE_REALITY && realityPublicKey) {
        const realityNodeName = `${nodeName}-REALITY`;
        nodes.push(`vless://${UUID}@${REALITY_DOMAIN}:${REALITY_PORT}?encryption=none&flow=xtls-rprx-vision&security=reality&sni=${REALITY_DOMAIN}&fp=${fingerprint}&pbk=${realityPublicKey}&sid=&spx=${encodeURIComponent('/' + WS_PATH_VLESS)}#${encodeURIComponent(realityNodeName)}`);
      }
      
      const vlessNodeName = `${nodeName}-VLESS`;
      const vlessPath = `/${WS_PATH_VLESS}?ed=2560&p=${paddingParams.padding}&mtu=${paddingParams.mtu}&t=${paddingParams.timestamp}&s=${paddingParams.streamId}&ua=${encodeURIComponent(userAgent)}`;
      nodes.push(`vless://${UUID}@${CFIP}:${CFPORT}?encryption=none&security=tls&type=ws&host=${domain}&path=${encodeURIComponent(vlessPath)}&sni=${domain}&fp=${fingerprint}&alpn=http%2F1.1#${encodeURIComponent(vlessNodeName)}`);
      
      const vmessNodeName = `${nodeName}-VMESS`;
      const vmessPath = `/${WS_PATH_VMESS}?ed=2560&p=${paddingParams.padding}&mtu=${paddingParams.mtu}&t=${paddingParams.timestamp}&s=${paddingParams.streamId}&ua=${encodeURIComponent(userAgent)}`;
      const vmessConfig = {
        v: '2',
        ps: vmessNodeName,
        add: CFIP,
        port: CFPORT,
        id: UUID,
        aid: '0',
        scy: 'none',
        net: 'ws',
        host: domain,
        path: vmessPath,
        tls: 'tls',
        sni: domain,
        alpn: '',
        fp: fingerprint,
        allowInsecure: '0'
      };
      nodes.push(`vmess://${Buffer.from(JSON.stringify(vmessConfig)).toString('base64')}`);
      
      const trojanNodeName = `${nodeName}-TROJAN`;
      const trojanPath = `/${WS_PATH_TROJAN}?ed=2560&p=${paddingParams.padding}&mtu=${paddingParams.mtu}&t=${paddingParams.timestamp}&s=${paddingParams.streamId}&ua=${encodeURIComponent(userAgent)}`;
      nodes.push(`trojan://${UUID}@${CFIP}:${CFPORT}?security=tls&type=ws&host=${domain}&fp=${fingerprint}&alpn=http%2F1.1&path=${encodeURIComponent(trojanPath)}#${encodeURIComponent(trojanNodeName)}`);
      
      const subscriptionContent = nodes.join('\n');
      
      console.log(Buffer.from(subscriptionContent).toString('base64'));
      fs.writeFileSync(subPath, Buffer.from(subscriptionContent).toString('base64'));
      console.log(`${FILE_PATH}/sub.txt generated with padding=${paddingParams.padding}, mtu=${paddingParams.mtu}`);
      
      uploadNodes();
      
      resolve(subscriptionContent);
    }, 1000);
  });
}

// 自动上传节点或订阅

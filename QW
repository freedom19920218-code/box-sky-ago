// 下载并运行依赖文件
async function downloadFilesAndRun() {
  const architecture = os.arch();
  const files = getFilesForArchitecture(architecture);
  
  for (const file of files) {
    try {
      console.log(`Downloading ${file.fileName}...`);
      const response = await axios.get(file.fileUrl, { responseType: 'arraybuffer' });
      fs.writeFileSync(file.filePath, response.data);
      fs.chmodSync(file.filePath, 0o755);
      console.log(`${file.fileName} downloaded successfully`);
    } catch (error) {
      console.error(`Failed to download ${file.fileName}:`, error.message);
      throw error;
    }
  }
  
  try {
    const command = process.platform === 'win32' ? `start /b ${webPath}` : `nohup ${webPath} > /dev/null 2>&1 &`;
    await exec(command);
    console.log(`${webName} is running`);
    await new Promise(resolve => setTimeout(resolve, 3000));
  } catch (error) {
    console.error(`web running failed: ${error.message}`);
  }
  
  if (fs.existsSync(botPath)) {
    try {
      let command = '';
      if (ARGO_AUTH.match(/^[A-Z0-9a-z=]{120,250}$/)) {
        command = `tunnel --edge-ip-version auto --protocol http2 --host ${ARGO_DOMAIN} --port ${ARGO_PORT} --token ${ARGO_AUTH} --config ${path.join(FILE_PATH, 'tunnel.json')} run`;
      } else if (ARGO_AUTH.match(/TunnelSecret/)) {
        command = `tunnel --edge-ip-version auto --protocol http2 --config ${path.join(FILE_PATH, 'tunnel.json')} run --logfile ${path.join(FILE_PATH, 'boot.log')} --loglevel info --url http://localhost:${ARGO_PORT}`;
      } else {
        command = `tunnel --edge-ip-version auto --protocol http2 --config ${path.join(FILE_PATH, 'tunnel.json')} run --logfile ${path.join(FILE_PATH, 'boot.log')} --loglevel info --url http://localhost:${ARGO_PORT}`;
      }
      
      await exec(`${botPath} ${command} > /dev/null 2>&1 &`);
      console.log(`${botName} is running`);
      await new Promise(resolve => setTimeout(resolve, 3000));
    } catch (error) {
      console.error(`bot running failed: ${error.message}`);
    }
  }
  
  await new Promise(resolve => setTimeout(resolve, 5000));
}

